{
	"name": "ghost-drive",
	"productName": "GhostDrive",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "P2P file sharing with multi-drive sessions",
	"upgrade": "pear://huqgaq6hxaqaf6chz5o6qmhc6funox861p6jdohji5uzotaawgjo",
	"imports": {
		"#read-asset": {
			"android": "./lib/read-asset.android.js",
			"default": "./lib/read-asset.js"
		},
		"process": {
			"bare": "bare-process",
			"default": "process"
		},
		"path": {
			"bare": "bare-path",
			"default": "path"
		},
		"http": {
			"bare": "bare-http1",
			"default": "http"
		},
		"fs": {
			"bare": "bare-fs",
			"default": "fs"
		},
		"os": {
			"bare": "bare-os",
			"default": "os"
		}
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:schema": "node build.cjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"test": "brittle-bare test/*.cjs",
		"build:darwin": "bare-build --out out/ghost-drive-darwin-arm64 --host darwin-arm64 --icon ghost.png --name GhostDrive --runtime bare-native/runtime build/index.js",
		"build:android": "bare-build --out out/android-arm64 --resources resources/android --host android-arm64 --manifest manifest.xml --identifier io.ghostdrive.app --name GhostDrive --runtime bare-native/runtime build/index.js",
		"clean": "rm -rf out build .svelte-kit"
	},
	"devDependencies": {
		"@hyperswarm/secret-stream": "^6.9.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.2.2",
		"bare-build": "^0.5.0",
		"brittle": "^3.0.0",
		"lunte": "^1.6.0",
		"prettier": "^3.8.1",
		"prettier-config-holepunch": "^2.0.0",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"require-asset": "^1.2.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"b4a": "^1.8.0",
		"bare-buffer": "^3.6.0",
		"bare-console": "^6.1.0",
		"bare-crypto": "^1.13.4",
		"bare-encoding": "^1.0.3",
		"bare-fetch": "^2.8.2",
		"bare-fs": "^4.6.0",
		"bare-http1": "^4.5.5",
		"bare-module": "^6.2.0",
		"bare-native": "^0.1.2",
		"bare-os": "^3.8.7",
		"bare-path": "^3.0.0",
		"bare-process": "^4.4.1",
		"bare-querystring": "^1.1.0",
		"bare-storage": "^1.1.0",
		"bare-stream": "^2.9.1",
		"bare-timers": "^3.2.1",
		"bare-url": "^2.4.2",
		"compact-encoding": "^2.19.2",
		"corestore": "^7.9.2",
		"distributed-drive": "^0.1.1",
		"esbuild": "^0.28.0",
		"hyperbee2": "^1.0.0",
		"hyperdb": "^6.6.1",
		"hyperdht-address": "^1.0.1",
		"hyperdrive": "^13.3.2",
		"hyperschema": "^1.20.1",
		"hyperswarm": "^4.17.0",
		"hyperswarm-capability": "^1.1.1",
		"localdrive": "^2.2.1",
		"paparam": "^1.10.1",
		"protomux": "^3.10.3",
		"protomux-rpc": "^1.9.0",
		"rabin-native": "^2.0.0",
		"ready-resource": "^1.2.0",
		"record-cache": "^2.0.0",
		"safety-catch": "^1.0.3",
		"sodium-native": "^5.1.0",
		"streamx": "^2.25.0",
		"sveltekit-adapter-bare": "file:../sveltekit-adapter-bare",
		"which-runtime": "^1.3.2"
	}
}
